NODE_ENV=development
PORT=4000
APP_NAME=Nexora API
API_PREFIX=/api/v1
APP_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nexora
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-123456
JWT_REFRESH_SECRET=replace-with-another-long-random-secret-654321
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
COOKIE_SECURE=false
REQUEST_SIZE_LIMIT=1mb
LOG_LEVEL=info
